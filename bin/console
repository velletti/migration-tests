#!/usr/bin/env php
<?php

require __DIR__ . '/../vendor/autoload.php';

use Symfony\Component\Console\Application;
use App\Command\CompareRunCommand;

use App\Command\InitProjectCommand;



$application = new Application('URL Compare Tool', '1.0.0');

// Registriere deinen Command
$application->addCommand(new CompareRunCommand());
$application->addCommand(new InitProjectCommand());

// Starte die CLI
try {
    $application->run();
} catch (Exception $e) {
    echo $e->getLine() . ' ' . $e->getMessage() . "\n";
}
