{
  "name": "jvelletti/url-compare-tool",
  "description": "Compare rendered HTML output of URLs across environments",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "*",
    "guzzlehttp/guzzle": "^7.9",
    "symfony/console": "^7.0",
    "symfony/css-selector": "^7.0",
    "symfony/dom-crawler": "^7.0",
    "symfony/yaml": "^8.0"
  },
  "require-dev": {
    "dbrekelmans/bdi": "^1.4",
    "phpunit/phpunit": "^11.0",
    "symfony/panther": "^2.4"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",

    "scripts": {
      "post-install-cmd": [
        "@bdi"
      ],
      "post-update-cmd": [
        "@bdi"
      ],
      "bdi": "vendor/bin/bdi detect drivers",
      "test": "phpunit"

    },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
