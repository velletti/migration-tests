# Default GitHub user
Host github.com
   HostName github.com
   IdentitiesOnly yes
   ConnectTimeout 10
   ServerAliveInterval 10
   ServerAliveCountMax 2
   IdentityFile ~/.ssh/enterprise


# Git repository for TYPO3-EXT:gridelements
