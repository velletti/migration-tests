Host github.com-enterprise
    HostName github.com
    User git
    IdentityFile ~/.ssh/enterprise
    IdentitiesOnly yes

Host git.allplan.com
 HostName git.allplan.com
 PreferredAuthentications publickey
 IdentityFile ~/.ssh/id_rsa
 
 
