project:
  newDomain: "https://wwwv13.allplan.com.ddev.site"
  oldDomain: "https://www.allplan.com"
  instance: "https://migration-tests.ddev.site"

  ignore:
    selectors:
      - "#nav-shop2026"
      - ".give-freely-root"
      - "#usercentrics-root"
      - "#nav-search"
      - "#nav-login"
      - "#nav-language"

  viewports:
    - { width: 400, height: 2000 }
    - { width: 1900, height: 2000 }

  output:
    reportDir: "public/reports"
    renderedDir: "public/rendered"
    dashboardDir: "public/dashboard"

  uris:
    - { uri: "/de/" , scrollTo': ".nav" }
    - { uri: "/de/system/systemvoraussetzungen/", scrollTo: '#c230659' }
    - { uri: "/samples/miscellaneous/function-matrix/", scrollTo: '.allplan_functionmatrix2026' }